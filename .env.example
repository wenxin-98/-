# ============================================
# 统一转发管理面板 — 环境配置
# ============================================

# 面板
PORT=9527
NODE_ENV=production

# JWT 密钥 (安装脚本会自动生成)
JWT_SECRET=
# JWT_SECRET 留空会自动基于主机名派生稳定密钥
# 生产环境建议手动设置: openssl rand -hex 32

# 数据库路径
DB_PATH=/opt/unified-panel/data/panel.db

# GOST v3 API
GOST_API=http://127.0.0.1:18080
GOST_BIN=/usr/local/bin/gost
GOST_CONFIG=/opt/unified-panel/data/gost/config.yaml

# 3X-UI
XUI_API=http://127.0.0.1:2053
XUI_USER=admin
XUI_PASS=admin

# 管理员 (首次启动自动创建)
ADMIN_USER=admin
ADMIN_PASS=admin123

# BBR 自动调参
BBR_AUTO_TUNE=false
BBR_TUNE_INTERVAL=120000
BBR_PROBE_INTERVAL=60000

# NAT 端口范围 (可选, 不设则不限制)
# 适用于 NAT VPS 只分配了特定端口范围的环境
# 设置后创建转发/入站时会自动校验端口是否在范围内
# PORT_RANGE_MIN=20000
# PORT_RANGE_MAX=30000

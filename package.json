{
  "name": "unified-panel",
  "version": "1.9.0",
  "description": "\u7edf\u4e00\u8f6c\u53d1\u7ba1\u7406\u9762\u677f - GOST + 3X-UI \u96c6\u6210",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:web": "cd web && npx vite",
    "build": "tsup src/index.ts --format esm --target node20 --clean --sourcemap",
    "build:web": "cd web && npx vite build",
    "build:all": "npm run build && npm run build:web",
    "start": "node dist/index.js",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.6.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "cron": "^3.1.0",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.36.0",
    "express": "^4.21.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "nanoid": "^5.0.0",
    "qrcode": "^1.5.4",
    "winston": "^3.14.0",
    "ws": "^8.20.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.28.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "@esbuild/linux-x64"
    ]
  }
}
